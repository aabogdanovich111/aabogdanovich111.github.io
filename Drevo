    <script>
        // ================================================================
        //  ДАННЫЕ
        // ================================================================

        const STORAGE_KEY = 'genealogy_tree_data';
        let people = [];
        let relations = [];
        let branches = [];
        let selectedId = null;
        let nextId = 1;
        let relationCounter = 1;
        let currentBranch = null;
        let lineStyle = 'straight';
        let dataJsonPath = '';

        let linkMode = null;
        let linkFirst = null;
        let isLinkModeActive = false;
        let pendingAddType = null;
        const PRODUCTION_MODE = true; // true — полный редактор, false — только просмотр
        let productionMode = PRODUCTION_MODE;
        let gridEnabled = true;
        const gridSize = 24;

        // ================================================================
        //  ЗАГРУЗКА / СОХРАНЕНИЕ
        // ================================================================

        function loadData() {
            try {
                const saved = localStorage.getItem(STORAGE_KEY);
                if (saved) {
                    const data = JSON.parse(saved);
                    people = data.people || [];
                    relations = data.relations || [];
                    branches = data.branches || [];
                    nextId = data.nextId || 1;
                    relationCounter = data.relationCounter || 1;
                    currentBranch = data.currentBranch || null;
                    lineStyle = data.lineStyle || 'straight';
                    // Значение флага из файла имеет приоритет над сохранённым состоянием.
                    productionMode = PRODUCTION_MODE;
                    return true;
                }
            } catch (e) { console.warn(e); }
            return false;
        }

        function getConfiguredDataPath() {
            const input = document.getElementById('jsonPathInput');
            const fromInput = input ? input.value.trim() : '';
            const fromQuery = new URLSearchParams(window.location.search).get('tree');
            return fromInput || fromQuery || '';
        }

        async function loadTreeFromPath(path = getConfiguredDataPath()) {
            if (!path) return false;
            try {
                const response = await fetch(path, { cache: 'no-store' });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const data = await response.json();
                if (!data || !Array.isArray(data.people)) {
                    throw new Error('JSON не содержит массива people');
                }
                people = data.people || [];
                relations = data.relations || [];
                branches = data.branches || [];
                nextId = data.nextId || 1;
                relationCounter = data.relationCounter || 1;
                currentBranch = data.currentBranch || null;
                lineStyle = data.lineStyle || 'straight';
                productionMode = PRODUCTION_MODE;
                dataJsonPath = path;
                const input = document.getElementById('jsonPathInput');
                if (input) input.value = path;
                updateStyleButtons();
                render();
                autoSave();
                showSaveStatus(true);
                return true;
            } catch (e) {
                console.warn('Не удалось загрузить JSON по пути:', path, e);
                showSaveStatus(false);
                return false;
            }
        }

        function saveData() {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify({
                    people, relations, branches, nextId, relationCounter, currentBranch, lineStyle, productionMode
                }));
                showSaveStatus(true);
            } catch (e) { showSaveStatus(false); }
        }

        function applyModeUI() {
            const toolbar = document.querySelector('.toolbar');
            if (toolbar) {
                toolbar.style.display = productionMode ? '' : 'none';
            }
            const panel = document.getElementById('infoPanel');
            if (panel) {
                panel.classList.toggle('read-only-mode', !productionMode);
            }
            const saveBtn = document.querySelector('.save-btn');
            if (saveBtn) {
                saveBtn.style.display = productionMode ? 'block' : 'none';
            }
            const editForm = document.getElementById('editPanelForm');
            const readOnlyInfo = document.getElementById('readOnlyInfo');
            if (editForm) {
                editForm.style.display = productionMode ? 'block' : 'none';
            }
            if (readOnlyInfo) {
                readOnlyInfo.style.display = productionMode ? 'none' : 'block';
            }
            const controls = document.querySelectorAll('#panelBody input, #panelBody textarea, #panelBody select');
            controls.forEach((control) => {
                const isReadOnly = !productionMode;
                control.disabled = isReadOnly;
                control.readOnly = isReadOnly;
            });
        }

        function clearTree() {
            if (!productionMode) return;
            if (!confirm('Удалить все данные дерева? Это действие нельзя отменить.')) return;
            people = [];
            relations = [];
            branches = [];
            selectedId = null;
            currentBranch = null;
            nextId = 1;
            relationCounter = 1;
            lineStyle = 'straight';
            pendingAddType = null;
            isLinkModeActive = false;
            linkMode = null;
            linkFirst = null;
            document.getElementById('linkHint').style.display = 'none';
            wrapper.classList.remove('link-mode');
            document.body.style.cursor = '';
            updateStyleButtons();
            render();
            saveData();
        }

        function showSaveStatus(success) {
            const el = document.getElementById('saveStatus');
            el.textContent = success ? '✓ Сохранено' : '✗ Ошибка';
            el.style.color = success ? '#27ae60' : '#e74c3c';
            el.classList.add('show');
            clearTimeout(el._timeout);
            el._timeout = setTimeout(() => el.classList.remove('show'), 2000);
        }

        function autoSave() { saveData(); }

        // ================================================================
        //  ЭКСПОРТ / ИМПОРТ
        // ================================================================

        function exportData() {
            const data = { people, relations, branches, nextId, relationCounter, currentBranch, lineStyle, exportedAt: new Date().toISOString() };
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `genealogy_tree_${new Date().toISOString().slice(0, 10)}.json`;
            a.click();
            URL.revokeObjectURL(a.href);
        }

        function importData(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (e) => {
                try {
                    const data = JSON.parse(e.target.result);
                    if (data.people && data.relations) {
                        people = data.people || [];
                        relations = data.relations || [];
                        branches = data.branches || [];
                        nextId = data.nextId || 1;
                        relationCounter = data.relationCounter || 1;
                        currentBranch = data.currentBranch || null;
                        lineStyle = data.lineStyle || 'straight';
                        updateStyleButtons();
                        render();
                        autoSave();
                        alert('✅ Данные импортированы!');
                    } else {
                        alert('❌ Неверный формат');
                    }
                } catch (err) {
                    alert('❌ Ошибка: ' + err.message);
                }
            };
            reader.readAsText(file);
            event.target.value = '';
        }

        // ================================================================
        //  СТИЛЬ ЛИНИЙ
        // ================================================================

        function setLineStyle(style) {
            lineStyle = style;
            updateStyleButtons();
            render();
            autoSave();
        }

        function updateStyleButtons() {
            document.getElementById('styleStraight').classList.toggle('active-style', lineStyle === 'straight');
            document.getElementById('styleCorner').classList.toggle('active-style', lineStyle === 'corner');
        }

        function toggleGrid() {
            gridEnabled = !gridEnabled;
            const btn = document.getElementById('gridToggleBtn');
            if (btn) {
                btn.classList.toggle('active-grid', gridEnabled);
            }
            render();
            autoSave();
        }

        function snapPosition(person, x, y, freePlacement = false) {
            if (freePlacement || !gridEnabled) {
                return { x, y };
            }

            const threshold = 12;
            const gridX = Math.round(x / gridSize) * gridSize;
            const gridY = Math.round(y / gridSize) * gridSize;
            let snappedX = gridX;
            let snappedY = gridY;

            const others = people.filter(p => p.id !== person.id);
            for (const other of others) {
                const candidatesX = [
                    other.x,
                    other.x + other.width,
                    other.x - person.width,
                    other.x + other.width - person.width,
                    other.x + Math.round(other.width / 2) - Math.round(person.width / 2)
                ];
                const candidatesY = [
                    other.y,
                    other.y + other.height,
                    other.y - person.height,
                    other.y + other.height - person.height,
                    other.y + Math.round(other.height / 2) - Math.round(person.height / 2)
                ];

                for (const candidateX of candidatesX) {
                    if (Math.abs(x - candidateX) <= threshold) {
                        snappedX = candidateX;
                        break;
                    }
                }
                for (const candidateY of candidatesY) {
                    if (Math.abs(y - candidateY) <= threshold) {
                        snappedY = candidateY;
                        break;
                    }
                }
            }

            return { x: snappedX, y: snappedY };
        }

        // ================================================================
        //  РИСОВАНИЕ ЛИНИЙ
        // ================================================================

        function drawLine(x1, y1, x2, y2, color, width, className, dataRel) {
            const group = document.createElementNS('http://www.w3.org/2000/svg', 'g');
            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');

            if (lineStyle === 'corner') {
                const midY = (y1 + y2) / 2;
                const d = `M ${x1} ${y1} L ${x1} ${midY} L ${x2} ${midY} L ${x2} ${y2}`;
                path.setAttribute('d', d);
            } else {
                const d = `M ${x1} ${y1} L ${x2} ${y2}`;
                path.setAttribute('d', d);
            }

            path.setAttribute('stroke', color);
            path.setAttribute('stroke-width', width || '1');
            path.setAttribute('fill', 'none');
            path.setAttribute('stroke-linecap', 'round');
            path.setAttribute('stroke-linejoin', 'round');
            path.setAttribute('class', className || 'relation-line');
            if (dataRel) path.setAttribute('data-rel', dataRel);
            group.appendChild(path);

            return group;
        }

        function drawCornerLine(x1, y1, x2, y2, color, width, className, dataRel) {
            const group = document.createElementNS('http://www.w3.org/2000/svg', 'g');
            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            const midY = (y1 + y2) / 2;
            const d = `M ${x1} ${y1} L ${x1} ${midY} L ${x2} ${midY} L ${x2} ${y2}`;
            path.setAttribute('d', d);
            path.setAttribute('stroke', color);
            path.setAttribute('stroke-width', width || '1');
            path.setAttribute('fill', 'none');
            path.setAttribute('stroke-linecap', 'round');
            path.setAttribute('stroke-linejoin', 'round');
            path.setAttribute('class', className || 'corner-line');
            if (dataRel) path.setAttribute('data-rel', dataRel);
            group.appendChild(path);
            return group;
        }

        // ================================================================
