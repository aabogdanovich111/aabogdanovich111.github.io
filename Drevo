        // ================================================================
        //  АВТОМАТИЧЕСКОЕ ВЫРАВНИВАНИЕ
        // ================================================================

        function autoArrange() {
            const CARD_W = 160;
            const CARD_H = 50;
            const LEVEL_H = 80;
            const SPACING = 20;

            const marriages = relations.filter(r => r.type === 'marriage');

            marriages.forEach(marriage => {
                const p1 = people.find(p => p.id === marriage.from);
                const p2 = people.find(p => p.id === marriage.to);
                if (!p1 || !p2) return;

                const avgY = (p1.y + p2.y) / 2;
                p1.y = avgY;
                p2.y = avgY;

                const minX = Math.min(p1.x, p2.x);
                const maxX = Math.max(p1.x, p2.x);
                const centerX = (minX + maxX) / 2;
                p1.x = centerX - CARD_W - SPACING;
                p2.x = centerX + SPACING;
            });

            const childRelations = relations.filter(r => r.type === 'child');
            const childrenByMarriage = childRelations.reduce((groups, rel) => {
                if (!groups[rel.from]) groups[rel.from] = [];
                groups[rel.from].push(rel);
                return groups;
            }, {});

            Object.keys(childrenByMarriage).forEach(marriageId => {
                const marriage = relations.find(r => r.id === marriageId);
                if (!marriage) return;
                const parent1 = people.find(p => p.id === marriage.from);
                const parent2 = people.find(p => p.id === marriage.to);
                if (!parent1 || !parent2) return;

                const children = childrenByMarriage[marriageId]
                    .map(rel => people.find(p => p.id === rel.to))
                    .filter(Boolean);
                if (children.length === 0) return;

                const maxParentY = Math.max(parent1.y, parent2.y);
                const centerX = (parent1.x + parent1.width + parent2.x) / 2;
                const totalWidth = children.reduce((sum, child) => sum + child.width, 0) + SPACING * (children.length - 1);
                let childX = centerX - totalWidth / 2;

                children.forEach(child => {
                    child.y = maxParentY + LEVEL_H;
                    child.x = childX;
                    childX += child.width + SPACING;
                });
            });

            render();
            autoSave();
            document.getElementById('saveStatus').textContent = '📐 Выровнено!';
            document.getElementById('saveStatus').classList.add('show');
            setTimeout(() => document.getElementById('saveStatus').classList.remove('show'), 2000);
        }

        // ================================================================
        //  НАВИГАЦИЯ
        // ================================================================

        const svg = document.getElementById('genealogySvg');
        const wrapper = document.getElementById('canvasWrapper');

        let scale = 16.0, panX = 0, panY = 0, isPanning = false;
        let panStartX = 0, panStartY = 0, panStartPanX = 0, panStartPanY = 0;
        let dragState = {
            isDragging: false,
            dragStarted: false,
            person: null,
            group: null,
            offsetX: 0,
            offsetY: 0,
            startX: 0,
            startY: 0
        };
        let dragFrame = null;

        function updateTransform() {
            svg.style.transform = `translate(${panX}px, ${panY}px) scale(${scale})`;
            document.getElementById('zoomInfo').textContent = Math.round(scale * 100) + '%';
        }

        function setScale(newScale, anchorX, anchorY) {
            newScale = Math.min(Math.max(newScale, 2), 30);
            if (newScale === scale) return;
            const beforeX = (anchorX - panX) / scale;
            const beforeY = (anchorY - panY) / scale;
            scale = newScale;
            panX = anchorX - beforeX * scale;
            panY = anchorY - beforeY * scale;
            updateTransform();
        }

        function centerCanvasOnPeople() {
            if (!people || people.length === 0) return;
            let minX = Infinity;
            let minY = Infinity;
            let maxX = -Infinity;
            let maxY = -Infinity;
            for (const person of people) {
                minX = Math.min(minX, person.x);
                minY = Math.min(minY, person.y);
                maxX = Math.max(maxX, person.x + (person.width || 0));
                maxY = Math.max(maxY, person.y + (person.height || 0));
            }
            if (minX === Infinity) return;
            const centerX = (minX + maxX) / 2;
            const centerY = (minY + maxY) / 2;
            const rect = wrapper.getBoundingClientRect();
            if (!rect.width || !rect.height) return;
            const point = svg.createSVGPoint();
            point.x = centerX;
            point.y = centerY;
            const ctm = svg.getScreenCTM();
            if (!ctm) return;
            const screen = point.matrixTransform(ctm);
            panX += rect.left + rect.width / 2 - screen.x;
            panY += rect.top + rect.height / 2 - screen.y;
            updateTransform();
        }

        function getCanvasPoint(clientX, clientY) {
            const point = svg.createSVGPoint();
            point.x = clientX;
            point.y = clientY;
            const ctm = svg.getScreenCTM();
            if (!ctm) {
                const rect = wrapper.getBoundingClientRect();
                return {
                    x: (clientX - rect.left - panX) / scale,
                    y: (clientY - rect.top - panY) / scale
                };
            }
            const transformed = point.matrixTransform(ctm.inverse());
            return {
                x: transformed.x,
                y: transformed.y
            };
        }

        function startPanFromPoint(clientX, clientY) {
            if (isLinkModeActive || pendingAddType) return;
            isPanning = true;
            panStartX = clientX;
            panStartY = clientY;
            panStartPanX = panX;
            panStartPanY = panY;
            wrapper.style.cursor = 'grabbing';
        }

        function updatePanFromPoint(clientX, clientY) {
            if (!isPanning) return;
            panX = panStartPanX + (clientX - panStartX);
            panY = panStartPanY + (clientY - panStartY);
            updateTransform();
        }

        function finishPan() {
            if (isPanning) {
                isPanning = false;
                wrapper.style.cursor = isLinkModeActive ? 'crosshair' : 'grab';
            }
        }

        wrapper.addEventListener('wheel', (e) => {
            e.preventDefault();
            const rect = wrapper.getBoundingClientRect();
            const anchorX = e.clientX - rect.left;
            const anchorY = e.clientY - rect.top;
            setScale(scale + (e.deltaY > 0 ? -0.4 : 0.4), anchorX, anchorY);
        }, { passive: false });

        wrapper.addEventListener('mousedown', (e) => {
            if (e.button === 0 && !e.target.closest('.card-group') && !isLinkModeActive && !pendingAddType) {
                startPanFromPoint(e.clientX, e.clientY);
            }
        });

        wrapper.addEventListener('touchstart', (e) => {
            if (e.touches.length !== 1) return;
            if (e.target.closest('.card-group')) return;
            if (isLinkModeActive || pendingAddType) return;
            e.preventDefault();
            startPanFromPoint(e.touches[0].clientX, e.touches[0].clientY);
        }, { passive: false });

        wrapper.addEventListener('click', (e) => {
            if (!pendingAddType) return;
            if (e.target.closest('.card-group')) return;
            const point = getCanvasPoint(e.clientX, e.clientY);
            if (pendingAddType === 'person') {
                addPerson(point.x, point.y);
            } else if (pendingAddType === 'children') {
                addChildrenCard(point.x, point.y);
            } else if (pendingAddType === 'branchLabel') {
                addBranchLabel(point.x, point.y);
            }
            cancelPendingAdd();
        });

        window.addEventListener('mousemove', (e) => {
            if (isPanning) {
                updatePanFromPoint(e.clientX, e.clientY);
            }
        });
        window.addEventListener('mouseup', () => {
            finishPan();
        });
        window.addEventListener('touchmove', (e) => {
            if (e.touches.length !== 1 || !isPanning) return;
            e.preventDefault();
            updatePanFromPoint(e.touches[0].clientX, e.touches[0].clientY);
        }, { passive: false });
        window.addEventListener('touchend', () => {
            finishPan();
        });
        window.addEventListener('touchcancel', () => {
            finishPan();
        });
        wrapper.addEventListener('contextmenu', (e) => e.preventDefault());

        window.addEventListener('mousemove', (e) => {
            if (dragState.isDragging && dragState.person) {
                if (!dragState.dragStarted) {
                    const dx = e.clientX - dragState.startX;
                    const dy = e.clientY - dragState.startY;
                    if (Math.hypot(dx, dy) < 4) return;
                    dragState.dragStarted = true;
                }
                const point = getCanvasPoint(e.clientX, e.clientY);
                const freePlacement = e.shiftKey;
                const snapped = snapPosition(
                    dragState.person,
                    point.x - dragState.offsetX,
                    point.y - dragState.offsetY,
                    freePlacement
                );
                dragState.person.x = snapped.x;
                dragState.person.y = snapped.y;
                if (!dragFrame) {
                    dragFrame = requestAnimationFrame(() => {
                        updateTransform();
                        render();
                        dragFrame = null;
                    });
                }
            } else if (isPanning) {
                panX = panStartPanX + (e.clientX - panStartX);
                panY = panStartPanY + (e.clientY - panStartY);
                updateTransform();
            }
        });

        window.addEventListener('mouseup', () => {
            if (dragState.isDragging) {
                const wasDragged = dragState.dragStarted;
                dragState.isDragging = false;
                dragState.dragStarted = false;
                if (dragState.group) dragState.group.style.cursor = 'pointer';
                dragState.person = null;
                dragState.group = null;
                if (dragFrame) {
                    cancelAnimationFrame(dragFrame);
                    dragFrame = null;
                }
                if (wasDragged) {
                    autoSave();
                }
            }
            finishPan();
        });

        function zoomIn() { scale = Math.min(scale + 1, 30); updateTransform(); }
        function zoomOut() { scale = Math.max(scale - 1, 2); updateTransform(); }
        function resetView() { scale = 20; panX = 0; panY = 0; updateTransform(); closePanel(); clearSelection(); cancelLinkMode(); }

        // ================================================================
        //  ДОБАВЛЕНИЕ КАРТОЧЕК
        // ================================================================

        function addPerson(x, y) {
            if (!productionMode) return;
            const branch = branches.find(b => b.id === currentBranch);
            people.push({
                id: 'p' + (nextId++),
                name: 'Новая персона',
                fullName: '',
                dates: '',
                notes: '',
                group: branch ? branch.name : '',
                branch: currentBranch,
                color: branch ? branch.color : '#' + Math.floor(Math.random() * 16777215).toString(16).padStart(6, '0'),
                x: x !== undefined ? x : 500 + Math.random() * 80 - 40,
                y: y !== undefined ? y : 350 + Math.random() * 80 - 40,
                width: 160,
                height: 50,
                isChildrenCard: false,
                childrenList: ''
            });
            render();
            autoSave();
        }

        function addChildrenCard(x, y) {
            if (!productionMode) return;
            const branch = branches.find(b => b.id === currentBranch);
            people.push({
                id: 'p' + (nextId++),
                name: 'Дети',
                fullName: '',
                dates: '',
                notes: '',
                group: branch ? branch.name : '',
                branch: currentBranch,
                color: '#2c3e50',
                x: x !== undefined ? x : 500 + Math.random() * 80 - 40,
                y: y !== undefined ? y : 450 + Math.random() * 80 - 40,
                width: 240,
                height: 150,
                isChildrenCard: true,
                childrenList: 'Новый потомок - \nЕщё один потомок - '
            });
            render();
            autoSave();
        }

        function addBranch() {
            if (!productionMode) return;
            const name = prompt('Название ветви:');
            if (!name) return;
            const color = prompt('Цвет (hex):', '#4a7a9a');
            branches.push({ id: 'b' + (branches.length + 1), name, color: color || '#4a7a9a' });
            currentBranch = branches[branches.length - 1].id;
            autoSave();
            render();
        }

        function addBranchLabel(x, y) {
            if (!productionMode) return;
            const branch = branches.find(b => b.id === currentBranch);
            const defaultText = branch ? branch.name : 'Ветка';
            const name = prompt('Текст подписи ветви:', defaultText);
            if (!name) return;
            const color = branch ? branch.color : '#7f8c8d';
            people.push({
                id: 'p' + (nextId++),
                name: name.trim(),
                fullName: '',
                dates: '',
                notes: '',
                group: branch ? branch.name : '',
                branch: currentBranch,
                color: color,
                x: x !== undefined ? x : 500 + Math.random() * 80 - 40,
                y: y !== undefined ? y : 450 + Math.random() * 80 - 40,
                width: 120,
                height: 36,
                isBranchLabel: true,
                isChildrenCard: false,
                childrenList: ''
            });
            render();
            autoSave();
        }

        // ================================================================
        //  РЕЖИМ СОЗДАНИЯ СВЯЗЕЙ
        // ================================================================

        function startLinkMode(type) {
            if (!productionMode) return;
            if (isLinkModeActive) cancelLinkMode();
            cancelPendingAdd();
            isLinkModeActive = true;
            linkMode = type;
            linkFirst = null;

            const hint = document.getElementById('linkHint');
            const labels = {
                line: '🔗 СВЯЗЬ: выберите первую карточку',
                marriage: '💍 БРАК: выберите первую карточку',
                child: '👶 РЕБЁНОК: кликните на КОЛЬЦО БРАКА, затем на карточку ребёнка'
            };
            document.getElementById('linkHintText').textContent = labels[type];
            hint.style.display = 'block';
            wrapper.classList.add('link-mode');
            document.body.style.cursor = 'crosshair';

            ['linkLineBtn', 'linkMarriageBtn', 'linkChildBtn'].forEach(id => {
                document.getElementById(id).classList.toggle('link-active',
                    (id === 'linkLineBtn' && type === 'line') ||
                    (id === 'linkMarriageBtn' && type === 'marriage') ||
                    (id === 'linkChildBtn' && type === 'child')
                );
            });
            clearSelection();
            render();
        }

        function startCreateCard(type) {
            if (!productionMode) return;
            cancelLinkMode();
            pendingAddType = type;
            clearSelection();
            const hint = document.getElementById('linkHint');
            const labels = {
                person: '➕ Кликните по полю, чтобы добавить карточку человека',
                children: '👨‍👩‍👧‍👦 Кликните по полю, чтобы добавить карточку со списком детей',
                branchLabel: '🏷 Кликните по полю, чтобы добавить подпись ветви'
            };
            document.getElementById('linkHintText').textContent = labels[type] || 'Кликните по полю';
            hint.style.display = 'block';
            wrapper.classList.add('link-mode');
            document.body.style.cursor = 'crosshair';
            render();
        }

        function cancelPendingAdd() {
            if (!pendingAddType) return;
            pendingAddType = null;
            document.getElementById('linkHint').style.display = 'none';
            wrapper.classList.remove('link-mode');
            document.body.style.cursor = '';
            render();
        }

        function cancelLinkMode() {
            isLinkModeActive = false;
            linkMode = null;
            linkFirst = null;
            pendingAddType = null;
            document.getElementById('linkHint').style.display = 'none';
            wrapper.classList.remove('link-mode');
            document.body.style.cursor = '';
            ['linkLineBtn', 'linkMarriageBtn', 'linkChildBtn'].forEach(id => {
                document.getElementById(id).classList.remove('link-active');
            });
            render();
        }

        function handleMarriageClick(relId) {
            if (!productionMode || !isLinkModeActive || linkMode !== 'child') return;
            if (!linkFirst) {
                linkFirst = relId;
                document.getElementById('linkHintText').textContent = '👶 РЕБЁНОК: теперь выберите карточку ребёнка';
                render();
            }
        }

        function handleCardClickForLink(id) {
            if (!productionMode || !isLinkModeActive) return false;

            if (linkMode === 'child') {
                if (!linkFirst) return true;
                relations.push({
                    id: 'rel_' + (relationCounter++),
                    from: linkFirst,
                    to: id,
                    type: 'child',
                    color: '#6688aa'
                });
                cancelLinkMode();
                render();
                autoSave();
                return true;
            }

            if (!linkFirst) {
                linkFirst = id;
                const person = people.find(p => p.id === id);
                const label = linkMode === 'line' ? '🔗 СВЯЗЬ' : '💍 БРАК';
                document.getElementById('linkHintText').textContent =
                    `${label}: выберите вторую карточку (первая: ${person ? person.name : '?'})`;
                render();
                return true;
            } else {
                if (linkFirst === id) return true;
                relations.push({
                    id: 'rel_' + (relationCounter++),
                    from: linkFirst,
                    to: id,
                    type: linkMode,
                    color: linkMode === 'marriage' ? '#e94560' : '#6688aa'
                });
                cancelLinkMode();
                render();
                autoSave();
                if (linkMode === 'marriage') {
                    setTimeout(autoArrange, 100);
                }
                return true;
            }
        }

        // ================================================================
        //  ДЕЙСТВИЯ
        // ================================================================

        function deleteSelected() {
            if (!productionMode || !selectedId) return;
            const person = people.find(p => p.id === selectedId);
            if (!confirm(`Удалить "${person?.name || 'персону'}" и все связи?`)) return;
            relations = relations.filter(r => r.from !== selectedId && r.to !== selectedId);
            relations = relations.filter(r => {
                if (r.type === 'child' && r.from === selectedId) return false;
                return true;
            });
            people = people.filter(p => p.id !== selectedId);
            selectedId = null;
            closePanel();
            render();
            autoSave();
        }

        function selectPerson(id) {
            if (!productionMode && isLinkModeActive) {
                return;
            }
            if (isLinkModeActive) {
                if (linkMode === 'child' && !linkFirst) return;
                handleCardClickForLink(id);
                return;
            }
            const person = people.find(p => p.id === id);
            selectedId = id;
            render();
            if (person && person.isBranchLabel && !productionMode) {
                closePanel();
                return;
            }
            showPersonInfo(id);
        }

        function clearSelection() { selectedId = null; render(); }

        // ================================================================
        //  ИНФОРМАЦИОННАЯ ПАНЕЛЬ
        // ================================================================

        let editingId = null;

        function showPersonInfo(id) {
            const person = people.find(p => p.id === id);
            if (!person) return;
            editingId = id;

            document.getElementById('infoPanel').classList.add('open');
            applyModeUI();
            document.getElementById('editName').value = person.name || '';
            document.getElementById('editFullName').value = person.fullName || '';
            document.getElementById('editDates').value = person.dates || '';
            document.getElementById('editGroup').value = person.group || '';
            document.getElementById('editNotes').value = person.notes || '';
            document.getElementById('editColor').value = person.color || '#4a7a9a';
            document.getElementById('editColorHex').value = person.color || '#4a7a9a';
            document.getElementById('editChildrenList').value = person.childrenList || '';

            document.getElementById('roName').textContent = person.name || '—';
            document.getElementById('roBranch').textContent = person.group || '—';
            document.getElementById('roDates').textContent = person.dates || '—';
            const biographyText = person.notes || (person.isChildrenCard ? person.childrenList || 'Список потомков' : '—');
            document.getElementById('roBiography').textContent = biographyText || '—';

            // Показываем/скрываем поля в зависимости от типа карточки
            const isChildren = person.isChildrenCard || false;
            document.getElementById('fullNameField').style.display = isChildren ? 'none' : 'block';
            document.getElementById('datesField').style.display = isChildren ? 'none' : 'block';
            document.getElementById('notesField').style.display = isChildren ? 'none' : 'block';
            document.getElementById('childrenListField').style.display = isChildren ? 'block' : 'none';

            // Меняем заголовок
            document.querySelector('.info-panel-header h2').textContent = productionMode
                ? (isChildren ? '📋 Редактирование списка' : '✏️ Редактирование')
                : 'Данные';

            const rels = relations.filter(r => r.from === id || r.to === id);
            const container = document.getElementById('editRelations');
            if (rels.length === 0) {
                container.innerHTML = '<div class="rel-item"><span class="rel-type">—</span> Нет связей</div>';
            } else {
                container.innerHTML = '';
                rels.forEach(r => {
                    if (r.type === 'child') {
                        const marriage = relations.find(m => m.id === r.from);
                        if (marriage) {
                            const child = people.find(p => p.id === r.to);
                            const parent1 = people.find(p => p.id === marriage.from);
                            const parent2 = people.find(p => p.id === marriage.to);
                            if (parent1 && parent2 && child) {
                                const div = document.createElement('div');
                                div.className = 'rel-item';
                                div.innerHTML = `
                                    <span class="rel-type">👶 Ребёнок</span>
                                    ${child.name}
                                    <span class="rel-parent-badge">от ${parent1.name} & ${parent2.name}</span>
                                    <button class="rel-delete" onclick="deleteRelation('${r.id}')">✕</button>
                                `;
                                container.appendChild(div);
                                return;
                            }
                        }
                        return;
                    }
                    let otherId = r.from === id ? r.to : r.from;
                    const other = people.find(p => p.id === otherId);
                    if (!other) return;
                    const div = document.createElement('div');
                    div.className = 'rel-item';
                    let type = r.type === 'marriage' ? '💍 Брак' : '🔗 Связь';
                    let styleBadge = '';
                    if (r.type === 'line') {
                        styleBadge = `<span class="rel-style">${lineStyle === 'corner' ? '┐ угловая' : '╱ прямая'}</span>`;
                    }
                    div.innerHTML = `
                        <span class="rel-type">${type}</span>
                        ${other.name}
                        ${styleBadge}
                        <button class="rel-delete" onclick="deleteRelation('${r.id}')">✕</button>
                    `;
                    container.appendChild(div);
                });
            }
        }

        function updateCardSize(person) {
            if (person.isChildrenCard) return;
            if (person.isBranchLabel) {
                const text = (person.name || 'Ветка').trim();
                const width = Math.max(150, Math.min(420, text.length * 11 + 28));
                person.width = width;
                person.height = 44;
                return;
            }
            const fullName = (person.fullName || person.name || '').trim();
            const parts = fullName.split(/\s+/).filter(Boolean);
            let lines = [];
            if (parts.length === 0) {
                lines = [person.name || 'Без имени'];
            } else if (parts.length === 1) {
                lines = [parts[0]];
            } else if (parts.length === 2) {
                lines = [parts[0], parts[1]];
            } else {
                lines = [parts[0], parts[1], parts.slice(2).join(' ')];
            }
            const textWidths = lines.map(line => line.length * 9 + 28);
            const datesWidth = person.dates ? person.dates.length * 8 + 28 : 0;
            const width = Math.max(
                220,
                Math.min(
                    520,
                    Math.max(...textWidths, datesWidth)
                )
            );
            const hasDates = Boolean(person.dates);
            const height = Math.max(90, 24 + lines.length * 24 + (hasDates ? 24 : 0));
            person.width = width;
            person.height = height;
        }

        function savePerson() {
            if (!productionMode || !editingId) return;
            const person = people.find(p => p.id === editingId);
            if (!person) return;

            person.name = document.getElementById('editName').value || 'Без имени';

            if (!person.isChildrenCard) {
                person.fullName = document.getElementById('editFullName').value;
                person.dates = document.getElementById('editDates').value;
                person.notes = document.getElementById('editNotes').value;
                updateCardSize(person);
            } else {
                person.childrenList = document.getElementById('editChildrenList').value;
                // Автоматически обновляем размер карточки под количество детей
                const lines = person.childrenList.split('\n').filter(l => l.trim());
                person.height = Math.max(100, 50 + lines.length * 22);
            }

            person.group = document.getElementById('editGroup').value;
            person.color = document.getElementById('editColor').value;

            if (person.group && !branches.find(b => b.name === person.group)) {
                branches.push({ id: 'b' + (branches.length + 1), name: person.group, color: person.color });
            }

            render();
            autoSave();
            showSaveStatus(true);
        }

        function deleteRelation(relId) {
            if (!productionMode) return;
            const rel = relations.find(r => r.id === relId);
            if (rel && rel.type === 'marriage') {
                const childRels = relations.filter(r => r.from === relId);
                if (childRels.length > 0) {
                    if (!confirm(`Удалить брак и всех детей (${childRels.length})?`)) return;
                    relations = relations.filter(r => r.from !== relId);
                }
            }
            if (!confirm('Удалить эту связь?')) return;
            relations = relations.filter(r => r.id !== relId);
            render();
            autoSave();
            if (editingId) showPersonInfo(editingId);
        }

        function closePanel() { document.getElementById('infoPanel').classList.remove('open'); editingId = null; }

        document.getElementById('editColor').addEventListener('input', function () {
            document.getElementById('editColorHex').value = this.value;
        });

        document.getElementById('editColorHex').addEventListener('input', function () {
            const value = this.value.trim();
            if (/^#[0-9A-Fa-f]{6}$/.test(value)) {
                document.getElementById('editColor').value = value;
            }
        });

        document.querySelectorAll('.color-swatch').forEach((button) => {
            button.addEventListener('click', () => {
                const color = button.dataset.color;
                document.getElementById('editColor').value = color;
                document.getElementById('editColorHex').value = color;
                document.getElementById('editColorHex').dispatchEvent(new Event('input'));
            });
        });

        // ================================================================
        //  ОТРИСОВКА
        // ================================================================

        function render() {
            while (svg.firstChild) svg.removeChild(svg.firstChild);

            const linesGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
            linesGroup.setAttribute('id', 'linesGroup');

            const marriageRings = [];

            relations.forEach(rel => {
                if (rel.type === 'marriage') {
                    const from = people.find(p => p.id === rel.from);
                    const to = people.find(p => p.id === rel.to);
                    if (from && to) {
                        const cx = (from.x + from.width + to.x) / 2;
                        const cy = (from.y + from.height / 2 + to.y + to.height / 2) / 2;
                        marriageRings.push({ id: rel.id, x: cx, y: cy });
                    }
                }
            });

            relations.forEach(rel => {
                if (rel.type === 'child') {
                    const ring = marriageRings.find(r => r.id === rel.from);
                    const child = people.find(p => p.id === rel.to);
                    if (ring && child) {
                        const startX = ring.x;
                        const startY = ring.y;
                        const endX = child.x + child.width / 2;
                        const endY = child.y;
                        const lineGroup = drawLine(
                            startX, startY,
                            endX, endY,
                            '#000000', '2.5', 'relation-line', rel.id
                        );
                        const childLine = lineGroup.querySelector('line, path');
                        if (childLine) {
                            childLine.style.cursor = 'pointer';
                            childLine.addEventListener('click', (e) => {
                                e.stopPropagation();
                                if (!productionMode) return;
                                if (e.shiftKey) {
                                    relations = relations.filter(r => r.id !== rel.id);
                                    render();
                                    autoSave();
                                }
                            });
                        }
                        linesGroup.appendChild(lineGroup);
                    }
                    return;
                }

                if (rel.type === 'marriage') {
                    const from = people.find(p => p.id === rel.from);
                    const to = people.find(p => p.id === rel.to);
                    if (!from || !to) return;

                    const x1 = from.x + from.width;
                    const x2 = to.x;
                    const lineY = (from.y + from.height / 2 + to.y + to.height / 2) / 2;
                    const cx = (x1 + x2) / 2;
                    const cy = lineY;

                    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
                    const d = `M ${x1} ${lineY} L ${x2} ${lineY}`;
                    path.setAttribute('d', d);
                    path.setAttribute('stroke', rel.color || '#e94560');
                    path.setAttribute('stroke-width', '2');
                    path.setAttribute('fill', 'none');
                    path.setAttribute('opacity', '0.7');
                    path.setAttribute('stroke-linecap', 'round');
                    path.setAttribute('stroke-linejoin', 'round');
                    path.classList.add('relation-line');
                    linesGroup.appendChild(path);

                    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
                    circle.setAttribute('cx', cx);
                    circle.setAttribute('cy', cy);
                    circle.setAttribute('r', '18');
                    circle.setAttribute('fill', 'transparent');
                    circle.setAttribute('stroke', 'none');
                    circle.setAttribute('pointer-events', 'all');
                    circle.setAttribute('data-rel', rel.id);

                    circle.addEventListener('click', (e) => {
                        e.stopPropagation();
                        if (!productionMode) return;
                        if (e.shiftKey) {
                            const childRels = relations.filter(r => r.from === rel.id);
                            if (childRels.length > 0) {
                                if (!confirm(`Удалить брак и всех детей (${childRels.length})?`)) return;
                                relations = relations.filter(r => r.from !== rel.id);
                            }
                            relations = relations.filter(r => r.id !== rel.id);
                            render();
                            autoSave();
                            return;
                        }
                        if (isLinkModeActive && linkMode === 'child') {
                            handleMarriageClick(rel.id);
                        }
                    });
                    linesGroup.appendChild(circle);
                    return;
                }

                const from = people.find(p => p.id === rel.from);
                const to = people.find(p => p.id === rel.to);
                if (!from || !to) return;

                const x1 = from.x + from.width / 2;
                const y1 = from.y + from.height;
                const x2 = to.x + to.width / 2;
                const y2 = to.y;

                const lineGroup = drawLine(x1, y1, x2, y2, '#000000', '2', 'relation-line', rel.id);
                const line = lineGroup.querySelector('line, path');
                if (line) {
                    line.style.cursor = 'pointer';
                    line.addEventListener('click', (e) => {
                        e.stopPropagation();
                        if (!productionMode) return;
                        if (e.shiftKey) {
                            relations = relations.filter(r => r.id !== rel.id);
                            render();
                            autoSave();
                        }
                    });
                }
                linesGroup.appendChild(lineGroup);
            });

            svg.appendChild(linesGroup);

            // Карточки
            people.forEach(person => {
                updateCardSize(person);
                const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
                g.setAttribute('data-id', person.id);
                g.classList.add('card-group');
                if (person.isChildrenCard) {
                    g.classList.add('children-card');
                }
                if (person.isBranchLabel) {
                    g.classList.add('branch-label');
                }
                if (selectedId === person.id) g.classList.add('selected');
                if (isLinkModeActive && linkFirst === person.id && linkMode !== 'child') {
                    g.classList.add('link-first');
                }

                const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
                rect.setAttribute('x', person.x);
                rect.setAttribute('y', person.y);
                rect.setAttribute('width', person.width);
                rect.setAttribute('height', person.height);
                rect.setAttribute('fill', '#ffffff');
                rect.setAttribute('stroke', person.color || '#ece1cd');
                rect.setAttribute('stroke-width', '2.5');
                rect.setAttribute('rx', '8');
                rect.setAttribute('ry', '8');
                rect.classList.add('card-rect');
                if (person.isChildrenCard) {
                    rect.setAttribute('stroke-dasharray', '4,4');
                }
                g.appendChild(rect);

                if (person.isBranchLabel) {
                    const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                    label.setAttribute('x', person.x + person.width / 2);
                    label.setAttribute('y', person.y + person.height / 2 + 4);
                    label.setAttribute('font-size', '11');
                    label.setAttribute('font-weight', '700');
                    label.setAttribute('fill', '#1f1f1f');
                    label.setAttribute('text-anchor', 'middle');
                    label.textContent = person.name;
                    g.appendChild(label);
                } else if (person.isChildrenCard) {
                    // Карточка-список потомков
                    const title = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                    title.setAttribute('x', person.x + person.width / 2);
                    title.setAttribute('y', person.y + 16);
                    title.setAttribute('font-size', '9');
                    title.setAttribute('font-weight', '700');
                    title.setAttribute('fill', 'rgba(0, 0, 0, 0.55)');
                    title.setAttribute('text-anchor', 'middle');
                    title.setAttribute('class', 'card-title');
                    title.textContent = person.name.toUpperCase();
                    g.appendChild(title);

                    // Список потомков — любая строка текста
                    const lines = (person.childrenList || '').split('\n');
                    lines.forEach((line, index) => {
                        const yPos = person.y + 32 + index * 20;
                        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                        text.setAttribute('x', person.x + 12);
                        text.setAttribute('y', yPos);
                        text.setAttribute('font-size', '8.5');
                        text.setAttribute('fill', 'rgba(0, 0, 0, 0.75)');
                        text.setAttribute('class', 'child-item');
                        text.textContent = line;
                        g.appendChild(text);
                    });
                } else {
                    // Обычная карточка персоны
                    if (person.group) {
                        const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                        label.setAttribute('x', person.x + person.width - 8);
                        label.setAttribute('y', person.y + 10);
                        label.setAttribute('font-size', '6');
                        label.setAttribute('fill', 'rgba(255,255,255,0.5)');
                        label.setAttribute('text-anchor', 'end');
                        label.textContent = '🌿' + person.group.slice(0, 6);
                        g.appendChild(label);
                    }

                    const fullName = (person.fullName || person.name || '').trim();
                    const parts = fullName.split(/\s+/).filter(Boolean);
                    const firstLine = parts[0] || '';
                    const secondLine = parts[1] || '';
                    const thirdLine = parts.slice(2).join(' ');
                    const lineCount = [firstLine, secondLine, thirdLine].filter(Boolean).length;

                    const nameText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                    nameText.setAttribute('x', person.x + 26);
                    nameText.setAttribute('y', person.y + 32);
                    nameText.setAttribute('font-size', '16');
                    nameText.setAttribute('font-weight', '700');
                    nameText.setAttribute('fill', '#1f2937');
                    nameText.setAttribute('class', 'card-label');

                    if (firstLine) {
                        const line1 = document.createElementNS('http://www.w3.org/2000/svg', 'tspan');
                        line1.setAttribute('x', person.x + 26);
                        line1.setAttribute('dy', '0');
                        line1.textContent = firstLine;
                        nameText.appendChild(line1);
                    }
                    if (secondLine) {
                        const line2 = document.createElementNS('http://www.w3.org/2000/svg', 'tspan');
                        line2.setAttribute('x', person.x + 26);
                        line2.setAttribute('dy', '22');
                        line2.textContent = secondLine;
                        nameText.appendChild(line2);
                    }
                    if (thirdLine) {
                        const line3 = document.createElementNS('http://www.w3.org/2000/svg', 'tspan');
                        line3.setAttribute('x', person.x + 26);
                        line3.setAttribute('dy', '22');
                        line3.textContent = thirdLine;
                        nameText.appendChild(line3);
                    }

                    g.appendChild(nameText);

                    if (person.dates) {
                        const datesText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                        datesText.setAttribute('x', person.x + 26);
                        datesText.setAttribute('y', person.y + 32 + lineCount * 22);
                        datesText.setAttribute('font-size', '12');
                        datesText.setAttribute('fill', 'rgba(0, 0, 0, 0.6)');
                        datesText.setAttribute('class', 'card-sub date-line');
                        datesText.textContent = person.dates;
                        g.appendChild(datesText);
                    }
                }

                g.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const id = person.id;
                    if (isLinkModeActive) {
                        if (linkMode === 'child' && !linkFirst) return;
                        handleCardClickForLink(id);
                        return;
                    }
                    selectPerson(id);
                });

                g.addEventListener('mousedown', (e) => {
                    if (e.button === 0 && !e.ctrlKey && !e.altKey && !isLinkModeActive && productionMode) {
                        dragState.isDragging = true;
                        dragState.dragStarted = false;
                        dragState.person = person;
                        dragState.group = g;
                        dragState.startX = e.clientX;
                        dragState.startY = e.clientY;
                        const point = getCanvasPoint(e.clientX, e.clientY);
                        dragState.offsetX = point.x - person.x;
                        dragState.offsetY = point.y - person.y;
                        g.style.cursor = 'grabbing';
                        e.stopPropagation();
                    }
                });

                svg.appendChild(g);
            });
        }

        // ================================================================
        //  КЛАВИАТУРА
        // ================================================================

        document.addEventListener('keydown', (e) => {
            if (!productionMode) {
                if (e.key === 'Escape') {
                    closePanel();
                    clearSelection();
                }
                return;
            }
            if (e.ctrlKey && e.key === 'l') {
                e.preventDefault();
                startLinkMode('line');
            }
            if (e.ctrlKey && e.key === 'm') {
                e.preventDefault();
                startLinkMode('marriage');
            }
            if (e.ctrlKey && e.key === 'c') {
                e.preventDefault();
                startLinkMode('child');
            }
            if (e.ctrlKey && e.key === 'a') {
                e.preventDefault();
                autoArrange();
            }
            if (e.ctrlKey && e.key === '1') {
                e.preventDefault();
                setLineStyle('straight');
            }
            if (e.ctrlKey && e.key === '2') {
                e.preventDefault();
                setLineStyle('corner');
            }
            if (e.key === 'Escape') {
                if (isLinkModeActive) cancelLinkMode();
                else {
                    closePanel();
                    clearSelection();
                }
            }
            if ((e.key === 'Delete' || e.key === 'Backspace') && !e.target.closest('input, textarea')) {
                if (!isLinkModeActive) deleteSelected();
            }
            if (e.key === 'Enter' && editingId) savePerson();
        });

        // ================================================================
        //  ПОМОЩЬ
        // ================================================================

        function showHelp() { document.getElementById('helpModal').classList.add('show'); }
        function closeHelp() { document.getElementById('helpModal').classList.remove('show'); }
        document.getElementById('helpModal').addEventListener('click', (e) => {
            if (e.target === document.getElementById('helpModal')) closeHelp();
        });

        // ================================================================
        //  СТАРТ
        // ================================================================

        render();
        updateTransform();
        applyModeUI();
        if (people.length === 0) {
            setTimeout(() => {
                autoArrange();
                centerCanvasOnPeople();
            }, 300);
        } else {
            centerCanvasOnPeople();
        }

        console.log('✅ Древо загружено!');
        console.log('👨‍👩‍👦 Добавлена карточка "Список детей"');
        console.log('📝 Формат: ФИО - дата жизни (каждый на новой строке)');
    </script>

</body>

</html>
