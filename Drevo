        async function initializeApp() {
            const configuredPath = getConfiguredDataPath();
            if (configuredPath) {
                const loadedFromPath = await loadTreeFromPath(configuredPath);
                if (loadedFromPath) {
                    render();
                    updateTransform();
                    applyModeUI();
                    centerCanvasOnPeople();
                    console.log('✅ Древо загружено из JSON:', configuredPath);
                    return;
                }
            }

            const isNewData = !loadData();
            if (isNewData) initDemoData();
            updateStyleButtons();
            applyModeUI();
            render();
            updateTransform();
            if (people.length === 0) {
                setTimeout(() => {
                    autoArrange();
                    centerCanvasOnPeople();
                }, 300);
            } else {
                centerCanvasOnPeople();
            }
