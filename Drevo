<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Генеалогическое древо — конструктор</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #1a1a2e;
            display: flex;
            height: 100vh;
            overflow: hidden;
            color: #e0e0e0;
        }

        .main-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #16213e;
            position: relative;
            min-width: 0;
        }

        .toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            padding: 8px 14px;
            background: #0f3460;
            border-bottom: 2px solid #1a4a7a;
            align-items: center;
            flex-shrink: 0;
            min-height: 50px;
            z-index: 10;
        }

        .toolbar .brand {
            font-size: 16px;
            font-weight: 600;
            margin-right: 12px;
            color: #e94560;
            letter-spacing: 0.5px;
        }

        .toolbar .brand span {
            color: #fff;
        }

        .toolbar button {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.12);
            color: #fff;
            padding: 5px 12px;
            border-radius: 5px;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
            white-space: nowrap;
        }

        .toolbar button:hover {
            background: rgba(255, 255, 255, 0.18);
        }

        .toolbar button.primary {
            background: #e94560;
            border-color: #e94560;
        }

        .toolbar button.primary:hover {
            background: #ff6b81;
        }

        .toolbar button.danger {
            background: #c0392b;
            border-color: #c0392b;
        }

        .toolbar button.danger:hover {
            background: #e74c3c;
        }

        .toolbar button.success {
            background: #27ae60;
            border-color: #27ae60;
        }

        .toolbar button.success:hover {
            background: #2ecc71;
        }

        .toolbar button.link-active {
            background: #e94560;
            border-color: #e94560;
            animation: pulse-btn 1s ease-in-out infinite;
        }

        .toolbar button.active-style {
            background: #f39c12;
            border-color: #f39c12;
        }

        .toolbar button.active-grid {
            background: #27ae60;
            border-color: #27ae60;
        }

        @keyframes pulse-btn {

            0%,
            100% {
                box-shadow: 0 0 0 0 rgba(233, 69, 96, 0.5);
            }

            50% {
                box-shadow: 0 0 20px 5px rgba(233, 69, 96, 0.3);
            }
        }

        .toolbar .sep {
            width: 1px;
            height: 24px;
            background: rgba(255, 255, 255, 0.1);
            margin: 0 4px;
        }

        .toolbar .zoom-info {
            font-size: 11px;
            color: #8899bb;
            min-width: 40px;
            text-align: center;
        }

        .toolbar .save-status {
            font-size: 11px;
            color: #27ae60;
            margin-left: 6px;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .toolbar .save-status.show {
            opacity: 1;
        }

        .toolbar .json-path {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-left: 4px;
        }

        .toolbar .json-path input {
            min-width: 220px;
            padding: 5px 8px;
            border-radius: 5px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
            font-size: 12px;
        }

        .toolbar .json-path input::placeholder {
            color: #7b90ab;
        }

        .toolbar .style-label {
            font-size: 10px;
            color: #6688aa;
            margin: 0 4px;
        }

        .canvas-wrapper {
            flex: 1;
            overflow: hidden;
            position: relative;
            background: #efe3ce;
            cursor: grab;
        }

        .canvas-wrapper:active {
            cursor: grabbing;
        }

        .canvas-wrapper.link-mode {
            cursor: crosshair;
        }

        #genealogySvg {
            display: block;
            width: 100%;
            height: 100%;
            background: transparent;
            transform-origin: 0 0;
            overflow: visible;
        }

        .card-group {
            cursor: pointer;
        }

        .card-group:hover .card-rect {
            filter: brightness(1.15);
        }

        .card-group.selected .card-rect {
            filter: drop-shadow(0 0 12px rgba(233, 69, 96, 0.35));
        }

        .card-group.link-first .card-rect {
            filter: drop-shadow(0 0 16px rgba(241, 196, 15, 0.35));
        }

        .card-rect {
            transition: filter 0.15s, stroke-width 0.15s;
        }

        .card-label {
            pointer-events: none;
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 12px;
            font-weight: 600;
            fill: #1f1f1f;
        }

        .card-sub {
            pointer-events: none;
            font-family: Georgia, 'Times New Roman', serif;
            font-size: 9px;
            fill: rgba(0, 0, 0, 0.6);
        }

        .children-card .child-item {
            font-size: 10px;
            fill: rgba(0, 0, 0, 0.75);
        }

        .children-card .card-title {
            font-size: 10px;
            fill: rgba(0, 0, 0, 0.55);
        }

        .marriage-ring {
            cursor: pointer;
            transition: stroke-width 0.2s, r 0.2s;
        }

        .marriage-ring:hover {
            stroke-width: 4px !important;
            r: 18 !important;
        }

        .marriage-ring.highlight {
            stroke: #f1c40f !important;
            stroke-width: 5px !important;
            r: 20 !important;
            filter: drop-shadow(0 0 16px rgba(241, 196, 15, 0.6));
        }

        .relation-line {
            stroke-linecap: round;
            cursor: pointer;
            transition: stroke-width 0.2s;
        }

        .relation-line:hover {
            stroke-width: 3px !important;
        }

        .child-line {
            stroke-dasharray: 8, 5;
            stroke-linecap: round;
            cursor: pointer;
            transition: stroke-width 0.2s;
        }

        .child-line:hover {
            stroke-width: 3px !important;
        }

        .corner-line {
            fill: none;
            stroke-linejoin: round;
            cursor: pointer;
            transition: stroke-width 0.2s;
        }

        .corner-line:hover {
            stroke-width: 3px !important;
        }

        /* Стиль для карточки-списка потомков */
        .children-card .card-rect {
            stroke-dasharray: 4, 4;
            stroke-width: 2px;
        }

        .children-card .card-rect:hover {
            stroke-width: 3px;
        }

        .children-card .child-item {
            font-size: 8px;
            fill: rgba(0, 0, 0, 0.75);
            pointer-events: none;
        }

        .children-card .child-item .child-name {
            font-weight: 600;
        }

        .children-card .child-item .child-dates {
            fill: rgba(0, 0, 0, 0.55);
        }

        .children-card .card-title {
            font-size: 8px;
            font-weight: 700;
            fill: rgba(0, 0, 0, 0.45);
            pointer-events: none;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .branch-label .card-rect {
            stroke-width: 1.5;
            stroke-dasharray: 4, 4;
        }

        .branch-label .card-label {
            font-size: 11px;
            font-weight: 700;
        }

        .info-panel {
            width: 0;
            background: #0f3460;
            border-left: 2px solid #1a4a7a;
            overflow: hidden;
            transition: width 0.3s ease;
            display: flex;
            flex-direction: column;
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            height: 100vh;
            z-index: 15;
        }

        .info-panel.open {
            width: 380px;
        }

        .info-panel.read-only-mode {
            background: #ffffff;
            border-left: 2px solid #e5e1d8;
            box-shadow: -8px 0 24px rgba(0, 0, 0, 0.06);
        }

        .info-panel.read-only-mode .info-panel-header {
            background: #ffffff;
            border-bottom: 1px solid #ece7db;
        }

        .info-panel.read-only-mode .info-panel-header h2 {
            color: #2f2f2f;
        }

        .info-panel.read-only-mode .info-panel-header .close-btn {
            color: #7a7a7a;
        }

        .info-panel.read-only-mode .info-panel-body {
            padding: 18px;
            background: #ffffff;
        }

        .info-panel.read-only-mode .read-only-info {
            display: block;
        }

        .read-only-info {
            display: none;
        }

        .read-only-card {
            background: #ffffff;
            padding: 18px;
        }

        .read-only-title {
            font-size: 16px;
            font-weight: 700;
            color: #2f2f2f;
            margin-bottom: 14px;
            letter-spacing: 0.2px;
        }

        .read-only-stack {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .read-only-item {
            padding-bottom: 10px;
            border-bottom: 1px solid #f2eee6;
        }

        .read-only-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .read-only-label {
            display: block;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #8f8b82;
            margin-bottom: 4px;
        }

        .read-only-value {
            font-size: 14px;
            color: #1f1f1f;
            line-height: 1.45;
            white-space: pre-wrap;
        }

        .info-panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            border-bottom: 1px solid #1a4a7a;
            flex-shrink: 0;
        }

        .info-panel-header h2 {
            font-size: 15px;
            font-weight: 500;
            color: #fff;
        }

        .info-panel-header .close-btn {
            background: none;
            border: none;
            color: #8899bb;
            font-size: 20px;
            cursor: pointer;
            padding: 0 6px;
            transition: 0.2s;
        }

        .info-panel-header .close-btn:hover {
            color: #fff;
        }

        .info-panel-body {
            flex: 1;
            overflow-y: auto;
            padding: 16px 18px;
        }

        .info-panel-body::-webkit-scrollbar {
            width: 4px;
        }

        .info-panel-body::-webkit-scrollbar-thumb {
            background: #2a4a7a;
            border-radius: 4px;
        }

        .info-panel-body .field {
            margin-bottom: 12px;
        }

        .info-panel-body .field label {
            display: block;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #6688aa;
            margin-bottom: 2px;
        }

        .info-panel-body .field input,
        .info-panel-body .field textarea,
        .info-panel-body .field select {
            width: 100%;
            padding: 6px 10px;
            background: #0d1b2a;
            border: 1px solid #1a4a7a;
            border-radius: 5px;
            color: #fff;
            font-size: 13px;
            outline: none;
            transition: border 0.2s;
            font-family: inherit;
        }

        .color-row {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .color-row input[type="color"] {
            width: 44px;
            height: 44px;
            padding: 0;
            border-radius: 8px;
            border: 1px solid #1a4a7a;
            cursor: pointer;
        }

        .color-row input[type="text"] {
            width: 100%;
            max-width: 150px;
            padding: 8px 10px;
            background: #11213a;
            border: 1px solid #1a4a7a;
            border-radius: 8px;
            color: #fff;
            letter-spacing: 0.04em;
        }

        .color-row input[type="text"]:focus {
            border-color: #e94560;
        }

        .color-palette {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 10px;
        }

        .color-swatch {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.15);
            cursor: pointer;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

        .color-swatch:hover,
        .color-swatch:focus {
            transform: scale(1.05);
            box-shadow: 0 0 0 4px rgba(233, 69, 96, 0.12);
            outline: none;
        }

        .info-panel-body .field input:focus,
        .info-panel-body .field textarea:focus,
        .info-panel-body .field select:focus {
            border-color: #e94560;
        }

        .info-panel-body .field textarea {
            resize: vertical;
            min-height: 50px;
        }

        .info-panel-body .field input[type="color"] {
            width: 50px;
            height: 36px;
            padding: 2px;
            cursor: pointer;
        }

        .info-panel-body .field .color-row {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .info-panel-body .field .color-row span {
            font-size: 13px;
            color: #99aabb;
        }

        .info-panel-body .field select {
            appearance: auto;
        }

        .info-panel-body .field .relations-list {
            margin-top: 4px;
        }

        .info-panel-body .field .rel-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 4px 0;
            font-size: 12px;
            color: #c0c0d0;
        }

        .info-panel-body .field .rel-item .rel-type {
            color: #6688aa;
            font-size: 10px;
            min-width: 50px;
        }

        .info-panel-body .field .rel-item .rel-delete {
            background: none;
            border: none;
            color: #c0392b;
            cursor: pointer;
            font-size: 14px;
            margin-left: auto;
        }

        .info-panel-body .field .rel-item .rel-delete:hover {
            color: #e74c3c;
        }

        .info-panel-body .field .rel-item .rel-parent-badge {
            background: rgba(255, 255, 255, 0.08);
            padding: 0 8px;
            border-radius: 3px;
            font-size: 9px;
            color: #8899bb;
        }

        .info-panel-body .field .rel-item .rel-style {
            font-size: 9px;
            color: #6688aa;
            background: rgba(255, 255, 255, 0.05);
            padding: 0 6px;
            border-radius: 3px;
        }

        .info-panel-body .save-btn {
            width: 100%;
            padding: 8px;
            background: #27ae60;
            border: none;
            border-radius: 5px;
            color: #fff;
            font-size: 13px;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 8px;
        }

        .info-panel-body .save-btn:hover {
            background: #2ecc71;
        }

        .link-hint {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(233, 69, 96, 0.95);
            color: #fff;
            padding: 12px 28px;
            border-radius: 30px;
            font-size: 15px;
            font-weight: 600;
            z-index: 50;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.6);
            pointer-events: none;
            animation: pulse 1.5s ease-in-out infinite;
            display: none;
            text-align: center;
        }

        .link-hint .cancel-hint {
            font-size: 12px;
            opacity: 0.7;
            display: block;
            margin-top: 4px;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
                transform: translateX(-50%) scale(1);
            }

            50% {
                opacity: 0.85;
                transform: translateX(-50%) scale(0.98);
            }
        }

        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(4px);
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal {
            background: #16213e;
            border: 1px solid #1a4a7a;
            border-radius: 14px;
            max-width: 580px;
            width: 90%;
            max-height: 80vh;
            overflow-y: auto;
            padding: 24px 30px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
        }

        .modal::-webkit-scrollbar {
            width: 4px;
        }

        .modal::-webkit-scrollbar-thumb {
            background: #2a4a7a;
            border-radius: 4px;
        }

        .modal h2 {
            color: #e94560;
            font-size: 20px;
            margin-bottom: 6px;
        }

        .modal .subtitle {
            color: #6688aa;
            font-size: 13px;
            margin-bottom: 16px;
        }

        .modal .step {
            display: flex;
            gap: 12px;
            margin-bottom: 12px;
            padding: 10px 14px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 6px;
            border-left: 3px solid #e94560;
        }

        .modal .step .num {
            font-size: 18px;
            font-weight: 700;
            color: #e94560;
            min-width: 26px;
        }

        .modal .step .text {
            font-size: 13px;
            color: #c0c0d0;
            line-height: 1.5;
        }

        .modal .step .text strong {
            color: #fff;
        }

        .modal .close-modal {
            margin-top: 16px;
            padding: 10px;
            background: #e94560;
            border: none;
            border-radius: 6px;
            color: #fff;
            font-size: 13px;
            cursor: pointer;
            transition: 0.2s;
            width: 100%;
        }

        .modal .close-modal:hover {
            background: #ff6b81;
        }

        @media (max-width: 768px) {
            body {
                height: 100dvh;
                overflow: hidden;
            }

            .main-area {
                min-height: 0;
            }

            .toolbar {
                padding: 8px 10px;
                gap: 6px;
                max-height: 40vh;
                overflow-y: auto;
                align-items: flex-start;
            }

            .toolbar .brand {
                font-size: 13px;
                margin-right: 6px;
            }

            .toolbar button {
                font-size: 10px;
                padding: 6px 8px;
                min-height: 36px;
            }

            .toolbar .sep {
                display: none;
            }

            .toolbar .style-label {
                display: none;
            }

            .toolbar .zoom-info {
                min-width: auto;
                margin-left: auto;
            }

            .canvas-wrapper {
                touch-action: none;
            }

            .info-panel.open {
                width: 100%;
                position: absolute;
                right: 0;
                top: 0;
                bottom: 0;
                z-index: 20;
                border-left: none;
            }

            .info-panel.read-only-mode .read-only-card {
                padding: 16px;
                border-radius: 12px;
            }

            .info-panel-body {
                padding: 12px;
            }

            .info-panel-body .field input,
            .info-panel-body .field textarea,
            .info-panel-body .field select {
                font-size: 14px;
                padding: 10px 12px;
            }

            .modal {
                padding: 16px;
                margin: 10px;
            }

            .link-hint {
                font-size: 12px;
                padding: 10px 18px;
                bottom: 15px;
                width: 92%;
                max-width: 360px;
            }
        }
    </style>
</head>

<body>

    <div class="main-area">
        <div class="toolbar">
            <div class="brand">🧬 <span>Древо</span></div>
            <button class="primary" onclick="startCreateCard('person')">➕ Человек</button>
            <button class="success" onclick="startCreateCard('children')">👨‍👩‍👧‍👦 Список детей</button>
            <button class="danger" onclick="deleteSelected()">🗑 Удалить</button>
            <button class="danger" onclick="clearTree()">🧹 Очистить</button>
            <span class="sep"></span>
            <button onclick="addBranch()">🌿 Ветвь</button>
            <button onclick="startCreateCard('branchLabel')">🏷 Подпись ветви</button>
            <span class="sep"></span>
            <button id="linkLineBtn" onclick="startLinkMode('line')">🔗 Связать</button>
            <button id="linkMarriageBtn" onclick="startLinkMode('marriage')">💍 Брак</button>
            <button id="linkChildBtn" onclick="startLinkMode('child')">👶 Ребёнок</button>
            <button onclick="cancelLinkMode()">✖ Отмена</button>
            <span class="sep"></span>
            <span class="style-label">Стиль линии:</span>
            <button id="styleStraight" class="active-style" onclick="setLineStyle('straight')">╱ Прямая</button>
            <button id="styleCorner" onclick="setLineStyle('corner')">┐ Угловая</button>
            <span class="sep"></span>
            <button onclick="zoomIn()">➕</button>
            <button onclick="zoomOut()">➖</button>
            <button onclick="resetView()">⟲</button>
            <span class="zoom-info" id="zoomInfo">100%</span>
            <span class="sep"></span>
            <div class="json-path">
                <input id="jsonPathInput" type="text" value="" placeholder="Путь к JSON, например: /static/tree.json" />
                <button onclick="loadTreeFromPath()">📦 Загрузить</button>
            </div>
            <span class="sep"></span>
            <button onclick="exportData()">💾 Экспорт</button>
            <button onclick="document.getElementById('importFile').click()">📂 Импорт</button>
            <input type="file" id="importFile" accept=".json" style="display:none" onchange="importData(event)" />
            <span class="sep"></span>
            <button onclick="autoArrange()">📐 Выровнять</button>
            <button id="helpBtn" onclick="showHelp()">❓</button>
            <span class="save-status" id="saveStatus">✓ Сохранено</span>
        </div>

        <div class="canvas-wrapper" id="canvasWrapper">
            <svg id="genealogySvg" viewBox="0 0 20000 20000" preserveAspectRatio="xMidYMid meet"></svg>
        </div>
    </div>

    <div class="info-panel" id="infoPanel">
        <div class="info-panel-header">
            <h2>Редактирование</h2>
            <button class="close-btn" onclick="closePanel()">✕</button>
        </div>
        <div class="info-panel-body" id="panelBody">
            <div id="readOnlyInfo" class="read-only-info">
                <div class="read-only-card">
                    <div class="read-only-title"></div>
                    <div class="read-only-stack">
                        <div class="read-only-item">
                            <span class="read-only-label">Имя</span>
                            <div class="read-only-value" id="roName">—</div>
                        </div>
                        <div class="read-only-item">
                            <span class="read-only-label">Ветвь</span>
                            <div class="read-only-value" id="roBranch">—</div>
                        </div>
                        <div class="read-only-item">
                            <span class="read-only-label">Годы жизни</span>
